{
  "name": "driveout",
  "private": true,
  "version": "9.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:master": "vite --port 5173 --strictPort",
    "dev:owner1": "vite --port 5174 --strictPort",
    "dev:admin": "vite --port 5175 --strictPort",
    "dev:offroad": "vite --port 5174 --strictPort",
    "build": "vite build",
    "repo:verify": "bash scripts/verify-driveout-repo.sh",
    "schema:release:current": "node -e \"import('./api/_lib/tenantSchemaRelease.js').then(({ CURRENT_TENANT_SCHEMA_RELEASE }) => console.log(JSON.stringify(CURRENT_TENANT_SCHEMA_RELEASE, null, 2)))\"",
    "schema:release:tenant": "node scripts/run-tenant-schema-release.mjs",
    "schema:upgrade:tenant": "node tmp/run_tenant_schema_upgrade_guarded.mjs",
    "schema:verify:tenant": "node tmp/verify_tenant_schema_release_guarded.mjs",
    "qa:rental-thread": "node scripts/run-rental-thread-qa.mjs",
    "qa:rental-live": "playwright test tests/playwright/rental-thread-live.spec.js",
    "maestro:install": "bash scripts/maestro/install-maestro.sh",
    "maestro:qa": "npm run maestro:local:web",
    "maestro:gate": "bash scripts/maestro/run-web-quality-gate.sh",
    "maestro:local:web": "bash scripts/maestro/run-local-web.sh",
    "maestro:regression": "bash scripts/maestro/run-web-regression.sh",
    "maestro:web": "bash scripts/maestro/run-web-smoke.sh",
    "audit:owner1:schema": "node tmp/diff_owner1_schema_guarded.mjs",
    "audit:owner1:public": "node tmp/diff_owner1_public_schema_guarded.mjs",
    "audit:owner1:report": "node tmp/report_owner1_schema_drift.mjs",
    "audit:owner1:sync-plan": "node -e \"import('./tmp/owner1_schema_baseline.mjs').then(async (baseline) => { const scope = await import('./tmp/owner1_schema_sync_scope.mjs'); console.log(JSON.stringify({ baseline: baseline.OWNER1_SCHEMA_BASELINE, scope }, null, 2)); })\"",
    "audit:owner1:cleanup-plan": "node tmp/prepare_owner1_exact_clone_cleanup_guarded.mjs",
    "audit:owner1:exact-clone-plan": "node tmp/exact_zero_owner1_clone_guarded.mjs",
    "audit:shared-tenancy:isolation": "node scripts/audit-shared-tenant-isolation.mjs",
    "audit:fleet:visibility": "node scripts/audit-vehicle-operational-visibility.mjs",
    "deploy:production": "npm run repo:verify && node scripts/deploy-production.mjs",
    "deploy:production:tenant-release": "npm run repo:verify && node scripts/deploy-production-with-tenant-release.mjs",
    "deploy:preview:hobby": "npm run repo:verify && node scripts/deploy-preview-hobby.mjs",
    "translations:build": "node scripts/build-translation-catalog.mjs",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@headlessui/react": "^1.7.19",
    "@heroicons/react": "^2.1.3",
    "@mui/material": "^5.15.18",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@reduxjs/toolkit": "^2.2.5",
    "@stripe/react-stripe-js": "^2.7.1",
    "@stripe/stripe-js": "^3.5.0",
    "@supabase/supabase-js": "^2.90.1",
    "@tanstack/react-query": "^5.37.1",
    "chart.js": "^4.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "file-saver": "^2.0.5",
    "firebase": "^10.12.2",
    "framer-motion": "^11.2.6",
    "heic-convert": "^2.1.0",
    "heic2any": "0.0.4",
    "html2canvas": "^1.4.1",
    "i18next": "^23.11.5",
    "i18next-browser-languagedetector": "^8.0.0",
    "jspdf": "^2.5.1",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.381.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.20.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-datepicker": "^6.9.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-i18next": "^14.1.2",
    "react-icons": "^5.2.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.23.1",
    "react-signature-canvas": "^1.0.6",
    "react-to-print": "^2.15.1",
    "recharts": "^2.12.7",
    "recordrtc": "^5.6.2",
    "redux-persist": "^6.0.0",
    "sharp": "^0.34.5",
    "signature_pad": "^4.2.0",
    "sonner": "^2.0.7",
    "stripe": "^15.8.0",
    "tailwind-merge": "^2.3.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "vite": "^5.2.11"
  }
}
